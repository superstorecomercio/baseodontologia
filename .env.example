# Opcional: avaliações Google na home (Places API — New)
# Console: https://console.cloud.google.com/ → Biblioteca → "Places API (New)" + faturamento
GOOGLE_PLACES_API_KEY=

# Opção A — Place ID (string que costuma começar com ChIJ…; pode vir como places/ChIJ…)
GOOGLE_PLACE_ID=

# Opção B — quando o link do Maps só tem `1s0x…:0x…` ou `/g/11…` (sem ChIJ na barra):
# Texto forte para o Text Search (nome + rua + bairro + cidade)
GOOGLE_PLACE_TEXT_QUERY=BASE Odontologia Inteligente, Rua Capitão Macedo 143, Vila Clementino, São Paulo SP
# Coordenadas do próprio link @lat,lon do Google Maps (ajuda a desambiguar)
GOOGLE_PLACE_SEARCH_BIAS_LATLON=-23.5933515,-46.641009

# Instagram — últimos posts (Graph API). Precisa: Instagram Profissional + Página Facebook ligada a ele.
# 1) App: https://developers.facebook.com/apps/ → criar app → produto "Instagram" / API do Instagram.
# 2) User ID (numérico): Graph API Explorer https://developers.facebook.com/tools/explorer/
#    → GET /me/accounts → pegar id da Página → GET /{page-id}?fields=instagram_business_account
#    → em instagram_business_account.id está o INSTAGRAM_USER_ID.
# 3) Token: no mesmo Explorer, gere token com permissões instagram_basic, pages_show_list, pages_read_engagement
#    (e o que o app pedir para ler mídia). Troque por token de longa duração (docs Meta "Long-Lived User Access Token").
# Docs: https://developers.facebook.com/docs/instagram-api/getting-started
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
